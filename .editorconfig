root = true

[*]
charset = utf-8
insert_final_newline = true
end_of_line = lf
trim_trailing_whitespace = true

[*.csproj]
indent_style = space
indent_size = 2

[*.{props,targets}]
indent_style = space
indent_size = 2

[*.sln]
indent_style = tab

[*.cs]
indent_style = tab
tab_width = 4
indent_size = 4
wrap_lines = true
csharp_style_var_for_built_in_types = true
csharp_style_var_when_type_is_apparent = true

[**/MyPluginInfo.cs]
dotnet_diagnostic.CA1707.severity = none

[BopSubtitleReader/Patches/*.cs]
dotnet_diagnostic.CA1707.severity = none
